# Hugging Face model (Unsloth 4-bit safetensors; converted to GGUF on first start)
HF_MODEL_ID=unsloth/Qwen2.5-3B-Instruct-unsloth-bnb-4bit

# Output GGUF path inside the shared volume
GGUF_PATH=/models/qwen2.5-3b-instruct.gguf

# Optional: Hugging Face token for gated models
# HF_TOKEN=

# llama-server settings
LLAMA_CTX_SIZE=8192
LLAMA_NGL=99
LLAMA_THREADS=8
LLAMA_PORT=9990

# Fallback: pre-built GGUF repo if conversion fails (uncomment to use)
# HF_GGUF_REPO=Qwen/Qwen2.5-3B-Instruct-GGUF
# HF_GGUF_FILE=qwen2.5-3b-instruct-q4_k_m.gguf
