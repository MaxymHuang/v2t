# Hugging Face model (ModelOpt NVFP4 safetensors; converted to GGUF on first start)
HF_MODEL_ID=nvidia/Qwen3-30B-A3B-NVFP4

# Output GGUF path inside the shared volume
GGUF_PATH=/models/qwen3-30b-a3b-nvfp4.gguf

# Optional: Hugging Face token for gated models
# HF_TOKEN=

# llama-server settings
LLAMA_CTX_SIZE=8192
LLAMA_NGL=99
LLAMA_THREADS=8
LLAMA_PORT=9990

# Fallback: pre-built GGUF repo if NVFP4 conversion fails (uncomment to use)
# HF_GGUF_REPO=Qwen/Qwen3-30B-A3B-GGUF
# HF_GGUF_FILE=qwen3-30b-a3b-q4_k_m.gguf
